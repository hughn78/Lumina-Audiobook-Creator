{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": false,
    "skipLibCheck": true,
    "outDir": "build-desktop",
    "rootDir": ".",
    "types": ["node"],
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "electron/**/*.ts",
    "server/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests"
  ]
}
