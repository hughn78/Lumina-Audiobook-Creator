{
  "name": "lumina-audiobook-creator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "build-desktop/electron/main.js",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:server": "tsx server/index.ts",
    "build": "vite build",
    "clean:metadata": "find . -name '._*' -delete",
    "build:desktop": "npm run build && tsc -p tsconfig.desktop.json",
    "verify:desktop": "npm run build:desktop",
    "dist:mac": "npm run clean:metadata && npm run build:desktop && electron-builder --mac dmg",
    "dist:win": "npm run clean:metadata && npm run build:desktop && electron-builder --win nsis",
    "dist:all": "npm run clean:metadata && npm run build:desktop && electron-builder --mac dmg --win nsis",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "node --test tests/*.test.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "epubjs": "^0.3.93",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "firebase": "^12.12.0",
    "idb": "^8.0.3",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "electron": "^35.2.0",
    "electron-builder": "^26.0.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.openclaw.lumina",
    "productName": "Lumina Audiobook Creator",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build-desktop/**/*",
      "vendor/kokoro-model/**/*",
      "package.json",
      "!**/._*",
      "!**/.DS_Store"
    ],
    "asarUnpack": [
      "build-desktop/server/**/*",
      "vendor/kokoro-model/**/*",
      "node_modules/ffmpeg-static/**/*"
    ],
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.11"
  }
}
